rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    
    // Função auxiliar para verificar se é admin
    function isAdmin() {
      return request.auth != null && request.auth.token.email in [
        'admin@escu.com.br'
      ];
    }
    
    // Função auxiliar para verificar se usuário pertence à escola
    function belongsToSchool(escolaId) {
      return request.auth != null && 
             exists(/databases/$(database)/documents/usuarios/$(request.auth.uid)) &&
             get(/databases/$(database)/documents/usuarios/$(request.auth.uid)).data.escolaId == escolaId;
    }
    
    // Regras para coleção 'escolas'
    match /escolas/{escolaId} {
      // Admins podem ler, criar, atualizar e deletar escolas
      allow read, write: if isAdmin();
      
      // Usuários podem apenas ler sua própria escola
      allow read: if request.auth != null && belongsToSchool(escolaId);
    }
    
    // Regras para coleção 'usuarios'
    match /usuarios/{userId} {
      // Admins podem ler, criar, atualizar e deletar qualquer usuário
      allow read, write: if isAdmin();
      
      // Usuário pode ler e atualizar seu próprio documento
      allow read, update: if request.auth != null && request.auth.uid == userId;
      
      // Permitir criação de novo documento com UID do Auth durante primeiro acesso
      // O documento temporário (criado pelo admin) será deletado e um novo será criado com o UID real
      allow create: if request.auth != null && 
                       request.resource.data.email == request.auth.token.email;
      
      // Permitir leitura para verificar email durante primeiro acesso (antes de qualquer auth)
      // Usando uma consulta by email - isto é seguro porque verifica se o email já existe
      allow read: if request.auth != null;
    }
    
    // Regras para coleção 'ocorrencias'
    match /ocorrencias/{ocorrenciaId} {
      // Usuários podem criar ocorrências para sua escola OU emails (documentos com 'to' e 'message')
      allow create: if request.auth != null && 
                      (belongsToSchool(request.resource.data.escolaId) || 
                       (request.resource.data.keys().hasAny(['to', 'message'])));
      
      // Usuários podem ler e atualizar ocorrências da sua escola (não emails)
      allow read, update: if request.auth != null && 
                            resource.data.escolaId != null &&
                            belongsToSchool(resource.data.escolaId);
      
      // Admins podem ler todas as ocorrências
      allow read: if isAdmin();
      
      // Usuários (professor, coordenador, diretor) podem deletar ocorrências da sua escola
      // OU o criador pode deletar sua própria ocorrência
      allow delete: if request.auth != null && 
                      resource.data.escolaId != null &&
                      belongsToSchool(resource.data.escolaId);
      
      // Admins podem deletar qualquer ocorrência
      allow delete: if isAdmin();
    }
    
    // Regras para coleção 'controleEntradaSaida'
    match /controleEntradaSaida/{controleId} {
      // Qualquer usuário autenticado pode ler, criar e atualizar
      allow read, write: if request.auth != null;
    }
    
    // Regras para coleção 'mail' (Firebase Extension: Trigger Email)
    match /mail/{mailId} {
      // Permite criar documentos (enviar emails) se autenticado
      allow create: if request.auth != null;
      
      // Não permite ler (segurança - conteúdo de emails é sensível)
      allow read: if false;
      
      // Não permite atualizar ou deletar (Firebase Extension gerencia)
      allow update, delete: if false;
    }

    // Regras para coleção 'agendaEquipamentos'
    match /agendaEquipamentos/{agendaId} {
      // Usuários autenticados podem ler todos os agendamentos
      allow read: if request.auth != null;
      
      // Usuários autenticados podem criar/editar/deletar agendamentos
      allow create, update, delete: if request.auth != null;
    }

    // Regras para coleção 'turmas'
    match /turmas/{turmaId} {
      // Usuários autenticados podem ler todas as turmas
      allow read: if request.auth != null;
      
      // Admins podem escrever
      allow write: if isAdmin();
    }

    // Regras para coleção 'alunos'
    match /alunos/{alunoId} {
      // Usuários da escola podem ler alunos
      allow read: if request.auth != null && belongsToSchool(resource.data.escolaId);
      
      // Secretaria pode criar e atualizar alunos da sua escola
      allow create, update: if request.auth != null && 
                                belongsToSchool(request.resource.data.escolaId) &&
                                get(/databases/$(database)/documents/usuarios/$(request.auth.uid)).data.role == 'secretaria';

      // Secretaria pode deletar alunos da sua escola
      allow delete: if request.auth != null && 
                       belongsToSchool(resource.data.escolaId) &&
                       get(/databases/$(database)/documents/usuarios/$(request.auth.uid)).data.role == 'secretaria';
    }

    // Regras para coleção 'faltas'
    match /faltas/{faltaId} {
      // Usuários da escola podem ler faltas
      allow read: if request.auth != null && belongsToSchool(resource.data.escolaId);
      
      // Secretaria pode criar e atualizar faltas
      allow create, update: if request.auth != null && 
                                belongsToSchool(request.resource.data.escolaId) &&
                                get(/databases/$(database)/documents/usuarios/$(request.auth.uid)).data.role == 'secretaria';

      // Secretaria pode deletar faltas (usa resource.data, não request.resource)
      allow delete: if request.auth != null && 
                       belongsToSchool(resource.data.escolaId) &&
                       get(/databases/$(database)/documents/usuarios/$(request.auth.uid)).data.role == 'secretaria';
    }

    // Regras para coleção 'conversas'
    match /conversas/{conversaId} {
      // Usuários autenticados podem ler e escrever conversas
      allow read, write: if request.auth != null;
    }

    // Regras para coleção 'buscaAtivaStatus'
    match /buscaAtivaStatus/{statusId} {
      // Usuários autenticados podem ler status
      allow read: if request.auth != null;
      
      // Coordenação e direção podem criar e atualizar status
      allow create, update: if request.auth != null && 
                             get(/databases/$(database)/documents/usuarios/$(request.auth.uid)).data.role in ['coordenacao', 'direcao', 'secretaria'];
      
      // Coordenação e direção podem deletar status
      allow delete: if request.auth != null && 
                    get(/databases/$(database)/documents/usuarios/$(request.auth.uid)).data.role in ['coordenacao', 'direcao', 'secretaria'];
    }

    // Regras para coleção 'faltasProfessores'
    match /faltasProfessores/{faltaId} {
      allow read: if request.auth != null && belongsToSchool(resource.data.escolaId);
      allow create: if request.auth != null &&
                       belongsToSchool(request.resource.data.escolaId) &&
                       get(/databases/$(database)/documents/usuarios/$(request.auth.uid)).data.role == 'secretaria';
      allow delete: if request.auth != null &&
                       belongsToSchool(resource.data.escolaId) &&
                       get(/databases/$(database)/documents/usuarios/$(request.auth.uid)).data.role == 'secretaria';
    }

    // Regras para coleção 'professores'
    match /professores/{professorId} {
      allow read: if request.auth != null && belongsToSchool(resource.data.escolaId);
      allow create: if request.auth != null &&
                       belongsToSchool(request.resource.data.escolaId) &&
                       get(/databases/$(database)/documents/usuarios/$(request.auth.uid)).data.role == 'secretaria';
      allow update: if request.auth != null &&
                       belongsToSchool(resource.data.escolaId) &&
                       get(/databases/$(database)/documents/usuarios/$(request.auth.uid)).data.role == 'secretaria';
      allow delete: if request.auth != null &&
                       belongsToSchool(resource.data.escolaId) &&
                       get(/databases/$(database)/documents/usuarios/$(request.auth.uid)).data.role == 'secretaria';
    }

    // Regras para coleção 'dadosFuncionaisProfessores'
    // Dados sigilosos (RG, CPF, matrícula) — apenas secretaria e direcao
    match /dadosFuncionaisProfessores/{professorId} {
      allow read: if request.auth != null &&
                     get(/databases/$(database)/documents/usuarios/$(request.auth.uid)).data.escolaId ==
                     resource.data.escolaId &&
                     get(/databases/$(database)/documents/usuarios/$(request.auth.uid)).data.role in ['secretaria', 'direcao'];
      allow write: if request.auth != null &&
                      get(/databases/$(database)/documents/usuarios/$(request.auth.uid)).data.escolaId ==
                      request.resource.data.escolaId &&
                      get(/databases/$(database)/documents/usuarios/$(request.auth.uid)).data.role in ['secretaria', 'direcao'];
    }

    // Regras para coleção 'diario' (Diário de Classe do Professor)
    match /diario/{entradaId} {
      // Professor pode ler e escrever apenas suas próprias entradas
      allow read: if request.auth != null &&
                     belongsToSchool(resource.data.escolaId);
      allow create: if request.auth != null &&
                       belongsToSchool(request.resource.data.escolaId) &&
                       request.resource.data.professorId == request.auth.uid;
      allow update, delete: if request.auth != null &&
                               resource.data.professorId == request.auth.uid;
    }

    // Regras para coleção 'horarios' (Horário semanal do professor)
    match /horarios/{horarioId} {
      // Professor pode ler o próprio horário (pertencente à sua escola)
      allow read: if request.auth != null &&
                     belongsToSchool(resource.data.escolaId);
      // Professor pode criar horário para si mesmo na própria escola
      allow create: if request.auth != null &&
                       belongsToSchool(request.resource.data.escolaId) &&
                       request.resource.data.professorId == request.auth.uid;
      // Professor pode atualizar/deletar apenas o próprio horário
      allow update, delete: if request.auth != null &&
                               resource.data.professorId == request.auth.uid;
    }
  }
}
